# GitHub token for the prs widget.
# Classic PAT needs `repo` + `read:user`. Fine-grained: read for issues/PRs in the orgs you care about.
GITHUB_TOKEN=ghp_replace_me

# Anthropic API key — powers the LLM-classified `alerts` widget.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-replace_me

# Linear personal API key — powers the `linear` widget (your assigned issues + unread inbox).
# Create one at https://linear.app/settings/api (Personal API keys → New API key).
LINEAR_API_KEY=lin_api_replace_me

# Google OAuth client — shared across Play Console + Firebase widgets.
# One-time setup: https://console.cloud.google.com/apis/credentials
#   1. Create an OAuth 2.0 Client ID, type "Web application"
#   2. Add authorized redirect URI: http://127.0.0.1:4321/oauth/google/callback
#   3. Enable "Google Play Android Developer API" + "Firebase Management API"
# Then paste the client ID + secret here and click "Connect Google" on /settings.
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
# Populated automatically after OAuth consent — do not set manually.
GOOGLE_REFRESH_TOKEN=replace_me
